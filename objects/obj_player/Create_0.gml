// Movement
vel_h = 0;
vel_v = 0;
velc = 3.0; // player movement speed

// Player stats
hp = 10;            // player health
atk = 1;            // damage per projectile
atk_cooldown = 0;   // attack cooldown
proj_speed = 6;     // projectile speed

// Shooting sound handle
shoot_sound = snd_shoot;

// Other gameplay variables (if needed)
max_hp = hp;        // optional, if you want max health tracking